# Kopieren nach .env und anpassen
NODE_ENV=production
PORT=3000

# JWT Secret - UNBEDINGT ändern! (min. 32 Zeichen)
JWT_SECRET=AENDERN_DIESEN_GEHEIMEN_SCHLUESSEL_HIER

# Ihre Domain (für QR-Code URLs)
BASE_URL=https://werkstatt.ihredomain.de

# DSGVO: Löschung abgeholter Fahrzeuge nach X Tagen (Standard: 30)
LOESCHUNG_NACH_TAGEN=30

# Datenbank-Pfad
DB_PATH=/data/werkstatt.db

# -------------------------------------------------------
# Werkstatt-Kontaktdaten (für Datenschutzerklärung)
# -------------------------------------------------------
WERKSTATT_NAME=Meine Werkstatt GmbH
WERKSTATT_STRASSE=Musterstraße 1
WERKSTATT_ORT=12345 Musterstadt
WERKSTATT_EMAIL_KONTAKT=info@meinewerkstatt.de
WERKSTATT_TELEFON=040 123456789

# -------------------------------------------------------
# E-Mail-Benachrichtigung (optional – leer lassen zum Deaktivieren)
# Kunden werden automatisch benachrichtigt wenn Status = "Fertig"
# -------------------------------------------------------
# SMTP_HOST=smtp.ionos.de
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@ihredomain.de
# SMTP_PASS=IhrPasswort
# SMTP_FROM=noreply@ihredomain.de
